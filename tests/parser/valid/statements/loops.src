fn test_while() -> int {
    int i = 0;
    int sum = 0;
    
    while (i < 10) {
        sum = sum + i;
        i = i + 1;
    }
    
    return sum;
}

fn test_for() -> int {
    int sum = 0;
    
    for (int i = 0; i < 10; i = i + 1) {
        sum = sum + i;
    }
    
    return sum;
}

fn test_for_cond() -> int {
    int i = 0;
    int sum = 0;
    
    for (; i < 10;) {
        sum = sum + i;
        i = i + 1;
    }
    
    return sum;
}

fn test_for_empty() -> int {
    int i = 0;
    
    for (;;) {
        i = i + 1;
        if (i > 100) {
            return i;
        }
    }
}

fn test_nested_loops() -> int {
    int sum = 0;
    
    for (int i = 0; i < 5; i = i + 1) {
        for (int j = 0; j < 5; j = j + 1) {
            sum = sum + i * j;
        }
    }
    
    return sum;
}